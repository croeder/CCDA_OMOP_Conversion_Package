                <raceCode nullFlavor="OTH">
                    <translation code="bad-translation-code" codeSystem="2.16.840.1.113883.6.238"/>
                </raceCode>
                <sdtc:raceCode code="1002-5" codeSystem="2.16.840.1.113883.6.238"/>
            </patient>
        </patientRole>
    </recordTarget>
