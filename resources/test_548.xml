                        </effectiveTime>
                        <performer typeCode="PRF">
                            <time nullFlavor="UNK"/>
                            <assignedEntity classCode="ASSIGNED">
                                <id root="2.16.840.1.113883.3.86.3.1" extension="PROV-IPD-002"/>
