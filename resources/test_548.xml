                                </assignedPerson>
                            </assignedEntity>
                        </performer>                        
                        <participant typeCode="LOC">
                            <participantRole classCode="SDLOC">
                            <id root="50905" extension="1.2.840.114350.1.13.297.2.7.2.686980.509050001"/>
                            </participantRole>
