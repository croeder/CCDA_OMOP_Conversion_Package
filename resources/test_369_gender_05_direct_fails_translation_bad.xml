    <recordTarget>
        <patientRole>
            <id extension="test-gender-05" root="2.16.840.1.113883.4.1"/>
            <patient>
                <birthTime value="19800105"/>
                <administrativeGenderCode code="bad-code" codeSystem="2.16.840.1.113883.5.1">
                    <translation code="another-bad-code" codeSystem="2.16.840.1.113883.5.1"/>
                </administrativeGenderCode>
            </patient>
        </patientRole>
    </recordTarget>
</ClinicalDocument>