        <patientRole>
            <id extension="test-gender-03" root="2.16.840.1.113883.4.1"/>
            <patient>
                <birthTime value="19800103"/>
                <administrativeGenderCode code="bad-code" codeSystem="2.16.840.1.113883.5.1">
                    <translation code="M" codeSystem="2.16.840.1.113883.5.1"/>
                </administrativeGenderCode>
            </patient>
        </patientRole>
    </recordTarget>
</ClinicalDocument>