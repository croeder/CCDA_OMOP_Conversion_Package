<?xml version="1.0" encoding="UTF-8"?>
<?xml-stylesheet type="text/xsl" href="CDA.xsl"?>
<!--
    Case 04: Tests a nullFlavor on the direct tag, forcing a fallback to a good translation.
-->
<ClinicalDocument xmlns="urn:hl7-org:v3">
    <recordTarget>
        <patientRole>
            <id extension="test-gender-04" root="2.16.840.1.113883.4.1"/>
            <patient>
                <birthTime value="19800104"/>
                <administrativeGenderCode nullFlavor="OTH">
                    <translation code="M" codeSystem="2.16.840.1.113883.5.1"/>
                </administrativeGenderCode>
            </patient>
        </patientRole>
    </recordTarget>
</ClinicalDocument>