<?xml version="1.0" encoding="UTF-8"?>
<?xml-stylesheet type="text/xsl" href="CDA.xsl"?>
<!--
    Case 12: Tests a nullFlavor falling back to a non-mappable translation and then a non-mappable sdtc.
-->
<ClinicalDocument xmlns="urn:hl7-org:v3" xmlns:sdtc="urn:hl7-org:sdtc">
    <recordTarget>
        <patientRole>
            <id extension="test-ethnicity-12" root="2.16.840.1.113883.4.1"/>
            <patient>
                <birthTime value="19800112"/>
                <ethnicGroupCode nullFlavor="OTH">
                    <translation code="bad-translation-code" codeSystem="2.16.840.1.113883.6.238"/>
                </ethnicGroupCode>
                <sdtc:ethnicGroupCode code="another-bad-code" codeSystem="2.16.840.1.113883.6.238"/>
            </patient>
        </patientRole>
    </recordTarget>
</ClinicalDocument>